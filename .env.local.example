# Copy this file to .env.local and fill in your own keys.
# .env.local is gitignored. Never commit real secrets.

# --- Gemini (embeddings, agent, sentiment) ---
# Get one at https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: agent chat model. Defaults to gemini-2.0-flash.
# Do NOT use gemini-flash-latest or gemini-pro-latest on the free tier: they map to Gemini 3
# models with very low limits (~5 generate_content calls/day), which breaks the multi-tool agent.
# Prefer: gemini-2.0-flash | gemini-2.5-flash | gemini-2.5-pro (if your key has access).
GEMINI_AGENT_MODEL=

# Optional: Reddit sentiment classifier. Defaults to gemini-2.0-flash.
GEMINI_SENTIMENT_MODEL=

# --- Supabase ---
# Project URL from Supabase Dashboard -> Settings -> API
SUPABASE_URL=
# Server secret: use the service_role / sb_secret key from the dashboard (never the anon/publishable key in the browser)
SUPABASE_SERVICE_ROLE_KEY=

# --- API-Football (MCP football tools; optional) ---
# https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=
